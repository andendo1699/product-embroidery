{%- assign personalise_variant = item.product.metafields.custom.personalise_variant.value -%}
{%- if personalise_variant != blank and item.product.metafields.custom.personalise.value != blank and item.variant.id != personalise_variant.id -%}
  {%- assign has_personalisation = false -%}
  {%- assign pg = item.properties._personalise_group -%}
  {%- if pg != blank -%}
    {%- assign has_personalisation = true -%}
  {%- endif -%}

  {%- assign linked_key = '' -%}
  {%- assign linked_variant_id = '' -%}
  {%- if has_personalisation -%}
    {%- for ci in cart.items -%}
      {%- if ci.properties._personalise_group == pg and ci.key != item.key -%}
        {%- assign linked_key = ci.key -%}
        {%- assign linked_variant_id = ci.variant_id -%}
        {%- break -%}
      {%- endif -%}
    {%- endfor -%}
  {%- endif -%}

  <cart-personalise-editor
    data-item-key="{{ item.key }}"
    data-linked-key="{{ linked_key }}"
    data-variant-id="{{ item.variant_id }}"
    data-linked-variant-id="{{ linked_variant_id }}"
    data-personalise-variant-id="{{ personalise_variant.id }}"
    data-personalise-group="{{ pg }}"
    data-quantity="{{ item.quantity }}"
    data-has-personalisation="{{ has_personalisation }}"
    class="block mt-4 p-4 bg-[#F5F5F5]"
  >
    <div class="flex items-center justify-between w-full">
      <label class="relative text-[1.4rem] flex break-words items-start cursor-pointer p-0 grow [&>svg]:bg-[rgb(var(--color-background))] [&>svg]:mr-3 [&>svg]:shrink-0">
        <input
          type="checkbox"
          data-personalise-toggle
          {% if has_personalisation %}checked{% endif %}
          class="peer absolute opacity-100 w-4 h-4 top-[0.2rem] -left-1 -z-10 appearance-none"
        >
        {{- 'square.svg' | inline_asset_content -}}
        <div class="invisible peer-checked:visible absolute left-[0.3rem] z-[5] top-[0.5rem] w-[1.1rem] h-[0.7rem]">
          {{- 'icon-checkmark.svg' | inline_asset_content -}}
        </div>
        <span>{{ personalise_variant.product.title | prepend: 'Add '  }} (+{{ personalise_variant.price | money }})</span>
      </label>
    </div>

    {%- if has_personalisation -%}
      <div data-personalise-summary class="text-[1.2rem] text-[#666] mt-1 pl-6">
        {%- assign summary_values = '' -%}
        {%- for prop in item.properties -%}
          {%- assign pfc = prop.first | slice: 0 -%}
          {%- if prop.last != blank and pfc == '_' and prop.first != '_personalise_group' -%}
            {%- if summary_values != '' -%}
              {%- assign summary_values = summary_values | append: ', ' -%}
            {%- endif -%}
            {%- assign summary_values = summary_values | append: '"' | append: prop.last | append: '"' -%}
          {%- endif -%}
        {%- endfor -%}
        {{ summary_values | prepend: ": " | prepend: personalise_variant.product.title }}
      </div>
    {%- endif -%}

    <div data-edit-form class="hidden mt-4">
      {%- for option in item.product.metafields.custom.personalise.value -%}
        {%- assign prop_name = '_' | append: option.label -%}
        {%- assign current_value = '' -%}
        {%- for prop in item.properties -%}
          {%- if prop.first == prop_name -%}
            {%- assign current_value = prop.last -%}
            {%- break -%}
          {%- endif -%}
        {%- endfor -%}

        <fieldset class="border-none p-0 mb-3">
          <legend class="text-[1.3rem] font-semibold mb-2">{{ option.label }} {% if option.limit %}(up to {{ option.limit }} characters ){% endif %}</legend>
          {%- if option.type == 'text' -%}
            <input
              type="text"
              name="_{{ option.label }}"
              value="{{ current_value | escape }}"
              class="field__input border border-[#D9D9D9] rounded !px-4 !py-2"
              maxlength="{{ option.limit }}"
            >
          {%- endif -%}

          {%- if option.type == 'color' -%}
            <div class="flex items-center flex-wrap gap-2">
              {%- for color_item in option.options.value -%}
                <div class="relative">
                  <input
                    type="radio"
                    id="cart-edit-{{ item.key | handle }}-{{ option.label | handleize }}-{{ forloop.index }}"
                    name="_{{ option.label }}"
                    value="{{ color_item }}"
                    {% if current_value == color_item %}checked{% endif %}
                    class="peer absolute opacity-0 w-0 h-0 pointer-events-none"
                  >
                  <label
                    for="cart-edit-{{ item.key | handle }}-{{ option.label | handleize }}-{{ forloop.index }}"
                    class="relative inline-block w-8 h-8 rounded-full border border-[#D9D9D9] cursor-pointer transition-shadow hover:shadow-[0_0_0_1px_rgba(var(--color-foreground),0.4)] peer-checked:shadow-[0_0_0_1px_rgba(var(--color-foreground),1)] peer-checked:border-[rgba(var(--color-foreground),1)]"
                    style="background-color: {{ color_item | default: 'white' }};"
                    title="{{ color_item }}"
                  ></label>
                </div>
              {%- endfor -%}
            </div>
          {%- endif -%}

          {%- if option.type == 'font' -%}
            <div class="!grid grid-cols-2 gap-2">
              {%- for font_item in option.options.value -%}
                <link href="https://fonts.googleapis.com/css2?family={{ font_item | replace: ' ', '+' }}&display=swap" rel="stylesheet">
                <div class="relative">
                  <input
                    type="radio"
                    id="cart-edit-{{ item.key | handle }}-{{ option.label | handleize }}-{{ forloop.index }}"
                    name="_{{ option.label }}"
                    value="{{ font_item }}"
                    {% if current_value == font_item %}checked{% endif %}
                    class="peer absolute opacity-0 w-0 h-0 pointer-events-none"
                  >
                  <label
                    for="cart-edit-{{ item.key | handle }}-{{ option.label | handleize }}-{{ forloop.index }}"
                    class="block w-full py-2 px-4 border border-[#D9D9D9] rounded text-center cursor-pointer text-[1.4rem] transition-colors bg-transparent hover:border-[rgba(var(--color-foreground),0.4)] peer-checked:border-[rgba(var(--color-foreground),1)] peer-checked:shadow-[0_0_0_1px_rgba(var(--color-foreground),1)]"
                    style="font-family: '{{ font_item }}', serif;"
                  >
                    {{ font_item }}
                  </label>
                </div>
              {%- endfor -%}
            </div>
          {%- endif -%}
        </fieldset>
      {%- endfor -%}

      <div class="flex gap-2 mt-4">
        <button type="button" data-save class="text-[1.3rem] py-[0.6rem] px-4 bg-[rgba(var(--color-foreground),1)] text-[rgb(var(--color-background))] border-none rounded cursor-pointer hover:opacity-85">
          Save
        </button>
        <button type="button" data-cancel class="text-[1.3rem] py-[0.6rem] px-4 bg-transparent border border-[#D9D9D9] rounded cursor-pointer">
          Cancel
        </button>
      </div>
    </div>
  </cart-personalise-editor>

  <style>
    cart-personalise-editor [data-save].loading {
      opacity: 0.6;
      pointer-events: none;
    }
  </style>
  <script src="{{ 'product-personalise.js' | asset_url }}" defer></script>
{%- endif -%}
